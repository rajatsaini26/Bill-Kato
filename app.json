{
  "expo": {
    "name": "Bill Kato",
    "slug": "billkato",
    "owner": "rajattak27",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "extra": {
      "eas": {
        "projectId": "58bfa34b-2513-448c-9893-dc38db225861"
      }
    },
    "splash": {
      "backgroundColor": "#1A56DB"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.billkato.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.billkato.app",
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1A56DB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "billkato",
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      "expo-web-browser",
      "expo-router"
    ]
  }
}